# Application
APP_ENV=local
APP_NAME=FCGAA Stats
SECRET_KEY=change-me-local-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
POSTGRES_DB=fcgaa_stats
POSTGRES_USER=fcgaa
POSTGRES_PASSWORD=fcgaa_local_password
DATABASE_URL=postgresql+psycopg://fcgaa:fcgaa_local_password@postgres:5432/fcgaa_stats

# Files
STORAGE_ROOT=/app/storage
MAX_UPLOAD_MB=100

# AI
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4.1-mini

# AI - Mistral historique
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest
AI_EXTERNAL_RESEARCH_ENABLED=false

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
